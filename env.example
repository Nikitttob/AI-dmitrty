# Скопируйте этот файл как .env и заполните значения
# cp .env.example .env

# API ключ Anthropic Claude (получить на console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-ваш-ключ-здесь

# Порт сервера (по умолчанию 3000)
PORT=3000

# Модель Claude (по умолчанию claude-sonnet-4-20250514)
MODEL=claude-sonnet-4-20250514
